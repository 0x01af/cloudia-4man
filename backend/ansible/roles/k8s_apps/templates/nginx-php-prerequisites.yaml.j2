---
apiVersion: v1
kind: Namespace
metadata:
  name: "{{ _k8s_app.namespace | default('nginx-php') }}"
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-php-configmap
  namespace: "{{ _k8s_app.namespace | default('nginx-php') }}"
data:
  zzz-nginx.conf: |
    server {
        listen 80;
        server_name {{ _k8s_app.nginx.fqdn | default('nginx-php.local') }};
        root /var/www/html;
        index index.php index.html;
{% for site in _k8s_app.nginx.sites %}
{% if site.path == "/" %}
        # ----------------------------------------------------
        # Site /
        # ----------------------------------------------------
        location / {
            root /var/www/html;
            try_files $uri $uri/ /index.php?$query_string;
        }
{% else %}
        # ----------------------------------------------------
        # Site {{ site.path }}
        # ----------------------------------------------------
        # Handle {{ site.path }} (without trailing slash) by redirecting to {{ site.path }}/
        location = {{ site.path }} {
            return 301 {{ site.path }}/;
        }
        
        location {{ site.path }}/ {
            root /var/www/html{{ site.path}};
            try_files $uri $uri/ {{ site.path }}/index.php?$query_string;
        }
{% endif %}
{% endfor %}
        # ----------------------------------------------------
        # Global PHP Handler for all sites
        # pass the PHP scripts to FastCGI server listening on 127.0.0.1:9000
        # ----------------------------------------------------
        location ~ \.php$ {
            # Check that the PHP file exists before passing to PHP-FPM
            try_files $uri =404;
            fastcgi_pass 127.0.0.1:9000;
            fastcgi_index index.php;
            include fastcgi_params;
            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        }
    }

  zzz-php-fpm.conf: |
    [global]
    daemonize = no
    
    [www]
    listen = 127.0.0.1:9000
    
    ; ### Process manager optimized for low memory
    pm = ondemand
    pm.max_children = 2
    pm.process_idle_timeout = 10s
    pm.max_requests = 500

---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: nginx-php-pv-wwwdata
  namespace: "{{ _k8s_app.namespace | default('nginx-php') }}"
  labels:
    app: nginx-php-app
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: "{{ _k8s_app.storage.size | default('1Gi') }}"
  storageClassName: "{{ _k8s_app.storage.class_name | default('') }}"
