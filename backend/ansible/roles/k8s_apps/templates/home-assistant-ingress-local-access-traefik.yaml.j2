---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: home-assistant-ingress-local-access
  namespace: "{{ _k8s_app.namespace | default('home-assistant') }}"
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web-local
spec:
  ingressClassName: {{ _k8s_ingress_detected }}
  rules:
    - host: "{{ _k8s_app.local_access.fqdn | default('home-assistant.local') }}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: home-assistant-service
                port:
                  number: 8123
