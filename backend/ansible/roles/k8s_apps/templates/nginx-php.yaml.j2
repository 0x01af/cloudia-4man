---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-php-app
  namespace: "{{ _k8s_app.namespace | default('nginx-php') }}"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: nginx-php-app
  template:
    metadata:
      labels:
        app: nginx-php-app
    spec:
      containers:
      # --- PHP Engine ---
      - name: php-fpm
        image: "php:{{ _k8s_app.config.php.version | default('7.4') }}-fpm-alpine"
        resources:
          requests:
            memory: "20Mi"
          limits:
            memory: "64Mi"
        volumeMounts:
        - name: web-root
          mountPath: /var/www/html

      # --- Nginx Webserver ---
      - name: nginx
        image: nginx:alpine
        resources:
          requests:
            memory: "8Mi"
          limits:
            memory: "32Mi"
        ports:
        - containerPort: 80
          name: http
        volumeMounts:
        - name: web-root
          mountPath: /var/www/html
        - name: nginx-config-volume
          mountPath: /etc/nginx/conf.d/default.conf
          subPath: default.conf
      volumes:
      - name: web-root
        persistentVolumeClaim:
          claimName: nginx-php-pv-config
      - name: nginx-config-volume
        configMap:
          name: nginx-php-config
---
apiVersion: v1
kind: Service
metadata:
  name: nginx-php-service
  namespace: "{{ _k8s_app.namespace | default('nginx-php') }}"
spec:
  type: ClusterIP
  ports:
  - port: 80
    targetPort: 80
    protocol: TCP
    name: http
  selector:
    app: nginx-php-app
