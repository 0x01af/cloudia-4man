# based on:
# - https://blog.quadmeup.com/2025/07/09/mosquitto-in-kubernetes-the-simple-way/
# - https://github.com/abalage/mosquitto-mqtt-k8s
---
apiVersion: v1
kind: Service
metadata:
  name: mosquitto-service
  namespace: "{{ _k8s_app.namespace | default('mosquitto') }}"
  labels:
    app: mosquitto-app
spec:
  type: ClusterIP
  ports:
    - port: 1883
      targetPort: 1883
      name: mqtt
    - port: 9001
      targetPort: 9001
      name: websocket
  selector:
    app: mosquitto-app
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: mosquitto-app
  namespace: "{{ _k8s_app.namespace | default('mosquitto') }}"
  labels:
    app: mosquitto-app
spec:
  replicas: 1
  selector:
    matchLabels:
      app: mosquitto-app
  template:
    metadata:
      labels:
        app: mosquitto-app
    spec:
      securityContext:
        fsGroup: 33
      containers:
      - image: "ghcr.io/eclipse-mosquitto/mosquitto:{{ _k8s_app.version }}-alpine"
        name: mosquitto
        resources:
          requests:
            memory: "32Mi"
            cpu: "10m"
          limits:
            memory: "64Mi"
            cpu: "250m"
        ports:
        - containerPort: 1883
          name: mqtt
        - containerPort: 9001
          name: websocket
        volumeMounts:
        # - name: mosquitto-pv-config
        #   mountPath: /mosquitto/config
        - name: mosquitto-configmap-config
          mountPath: /mosquitto/config/password_file.conf
          subPath: password_file.conf
          readOnly: true
        - name: mosquitto-configmap-config
          mountPath: /mosquitto/config/mosquitto.conf
          subPath: mosquitto.conf
      volumes:
      # - name: mosquitto-pv-config
      #   persistentVolumeClaim:
      #    claimName: mosquitto-pv-config
      - name: mosquitto-configmap-config
        configMap:
          name: mosquitto-configmap-config
