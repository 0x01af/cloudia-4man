---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: zigbee2mqtt-ingress-auth
  namespace: {{ _k8s_app.namespace | default('zigbee2mqtt') }}
spec:
  basicAuth:
    secret: zigbee2mqtt-secret-ingress
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: zigbee2mqtt-ingress-redirect
  namespace: {{ _k8s_app.namespace | default('zigbee2mqtt') }}
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
    traefik.ingress.kubernetes.io/router.middlewares: traefik-redirect-to-https@kubernetescrd
spec:
  ingressClassName: {{ }}
  rules:
    - host: {{ fqdn }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: zigbee2mqtt-service
                port:
                  number: 8080
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: zigbee2mqtt-ingress
  namespace: {{ _k8s_app.namespace | default('zigbee2mqtt') }}
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: "websecure"
    traefik.ingress.kubernetes.io/router.tls: "true"
    traefik.ingress.kubernetes.io/router.middlewares: {{ _k8s_app.namespace | default('zigbee2mqtt') }}-zigbee2mqtt-ingress-auth@kubernetescrd
    # configure test certificate issueing
    cert-manager.io/cluster-issuer: "letsencrypt-staging"
    # configure prod certificate issueing
    # cert-manager.io/cluster-issuer: "letsencrypt-prod"
    cert-manager.io/acme-challenge-type: "http01"
spec:
  ingressClassName: {{ }}
  rules:
  - host: {{ fqdn }}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: zigbee2mqtt-service
            port:
              number: 8080
  tls:
  - hosts:
    - {{ fqdn }}
    secretName: zigbee2mqtt-ingress-tls-secret
