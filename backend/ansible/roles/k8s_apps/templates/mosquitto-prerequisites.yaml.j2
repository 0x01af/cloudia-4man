---
apiVersion: v1
kind: Namespace
metadata:
  name: "{{ _k8s_app.namespace | default('mosquitto') }}"
---
# inspired by:
# - https://blog.quadmeup.com/2025/07/09/mosquitto-in-kubernetes-the-simple-way/
# - https://www.datacamp.com/de/tutorial/mosquitto-docker
# - https://shantanoo-desai.github.io/posts/technology/mosquitto_ansible_passgen/
kind: ConfigMap
apiVersion: v1
metadata:
  name: mosquitto-configmap-config
  namespace: "{{ _k8s_app.namespace | default('mosquitto') }}"
data:
  mosquitto.conf: |-
    # Basic listener configuration
    listener 1883
    protocol mqtt
    # mqtts: listener 8883
    # protocol mqtt

    # WebSocket listener
    listener 9001
    protocol websockets
    # https: listener 9002
    # protocol websockets

    # Encryption
    # cafile /mosquitto/config/ca.crt
    # certfile /mosquitto/config/server.crt
    # keyfile /mosquitto/config/server.key
     
    # Authentication
    allow_anonymous false
    password_file /mosquitto/config/password_file.conf

    # Persistence
    persistence false
    # persistence_location /mosquitto/data/
    # autosave_interval 300
    persistent_client_expiration 1d

    # Logging
    # log_dest file /mosquitto/log/mosquitto.log
    log_dest stdout
    log_timestamp true
    log_type error
    log_type warning
    # debugging: log_type notice
    # debugging: log_type information
    # # debugging: log_type debug
    # debugging: connection_messages true

  password_file.conf: |-
    {% for user in vault_k8s_apps.mosquitto.users %}
      {{ user.username }}:{{ user.password | mosquitto_passwd }}
    {% endfor %}
# ---
# apiVersion: v1
# kind: PersistentVolumeClaim
# metadata:
#   name: mosquitto-pv-config
#   namespace: "{{ _k8s_app.namespace | default('mosquitto') }}"
#   labels:
#     app: mosquitto-app
# spec:
#   accessModes:
#     - ReadWriteOnce
#   resources:
#     requests:
#       storage: "{{ _k8s_app.storage.size | default('1Gi') }}"
#   storageClassName: "{{ _k8s_app.storage.class_name | default('') }}"
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: mosquitto-certificate-tls
  namespace: "{{ _k8s_app.namespace | default('mosquitto') }}"
spec:
  secretName: mosquitto-ingress-secret-tls
  issuerRef:
    traefik.ingress.kubernetes.io/router.entrypoints: "websecure"
    traefik.ingress.kubernetes.io/router.tls: "true"
{% if _k8s_app.mode is defined and _k8s_app.mode == "prod" %}
{# configure prod certificate issueing #}
    name: "letsencrypt-production"
{% else %}
{# configure test certificate issueing #}
    name: "letsencrypt-staging"
{% endif %}
    kind: ClusterIssuer
  commonName: "{{ _k8s_app.mqtt.fqdn | default('mosquitto.local') }}"
  dnsNames:
    - "{{ _k8s_app.mqtt.fqdn | default('mosquitto.local') }}"
