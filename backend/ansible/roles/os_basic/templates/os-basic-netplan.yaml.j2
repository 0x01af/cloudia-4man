{{ ansible_managed | comment }}

network:
  version: 2
  renderer: networkd
  ethernets:
    eth0:
      accept-ra: false
      dhcp6: false
      dhcp4: false
      addresses:
        - {{ ip4.address }}
        - "{{ ip6.address }}"
      gateway4: {{ ip4.gateway }}
      gateway6: "{{ ip6.gateway }}"
      nameservers:
        search: [{{ dns.domain }}]
        addresses: [{{ dns.ip4 }}, "{{ dns.ip6 }}"]
