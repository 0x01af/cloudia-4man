{%- if k3s.storage.longhorn.backup_target.type != 'none' %}
---
apiVersion: v1
kind: Secret
metadata:
  name: longhorn-backup-secret
  namespace: longhorn-system
type: Opaque
stringData:
{% if k3s.storage.longhorn.backup_target.type == "cifs" %}
  CIFS_USERNAME: {{ vault_k3s.storage.longhorn.backup_target.access_id | to_json }}
  CIFS_PASSWORD: {{ vault_k3s.storage.longhorn.backup_target.access_key | to_json }}
{% elif k3s.storage.longhorn.backup_target.type == "aws-s3" %}
  AWS_ACCESS_KEY_ID: {{ vault_k3s.storage.longhorn.backup_target.access_id | to_json }}
  AWS_SECRET_ACCESS_KEY: {{ vault_k3s.storage.longhorn.backup_target.access_key | to_json }}
{% elif k3s.storage.longhorn.backup_target.type == "azure-blob" %}
  AZBLOB_ACCOUNT_NAME: {{ vault_k3s.storage.longhorn.backup_target.access_id | to_json }}
  AZBLOB_ACCOUNT_KEY: {{ vault_k3s.storage.longhorn.backup_target.access_key | to_json }}
{% elif k3s.storage.longhorn.backup_target.type == "gcp-storage" %}
  AWS_ACCESS_KEY_ID: {{ vault_k3s.storage.longhorn.backup_target.access_id | to_json }}
  AWS_ENDPOINTS: "https://storage.googleapis.com"
  AWS_SECRET_ACCESS_KEY: {{ vault_k3s.storage.longhorn.backup_target.access_key | to_json }}
{% endif %}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: longhorn-default-resource
  namespace: longhorn-system
data:
  default-resource.yaml: |
    "backup-target": "{{ k3s.storage.longhorn.backup_target.type }}://{{ k3s.storage.longhorn.backup_target.fqdn_path }}"
    "backup-target-credential-secret": "longhorn-backup-secret"
    "backupstore-poll-interval": "300"
{% endif %}
---
apiVersion: v1
kind: Secret
metadata:
  name: longhorn-ingress-secret
  namespace: longhorn-system
type: kubernetes.io/basic-auth
stringData:
  username: {{ vault_k3s.storage.longhorn.dashboard.username | to_json }}
  password: {{ vault_k3s.storage.longhorn.dashboard.password | to_json }}
